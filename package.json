{
  "name": "@praha/create-tsp",
  "version": "1.1.1",
  "description": "Create typescript package",
  "keywords": [
    "typescript",
    "package",
    "library"
  ],
  "homepage": "https://github.com/praha-inc/tsp/blob/main/README.md",
  "bugs": {
    "url": "https://github.com/praha-inc/tsp/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/praha-inc/tsp.git"
  },
  "license": "MIT",
  "author": "PrAha, Inc.",
  "sideEffects": false,
  "type": "module",
  "bin": "dist/index.js",
  "files": [
    "dist",
    "templates",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "rslib build",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "lint:code": "oxlint",
